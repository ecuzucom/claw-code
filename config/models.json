{
  "$schema": "https://opencode.ai/config.json",
  "models": {
    "claude-3-5-sonnet": {
      "provider": "anthropic",
      "endpoint": "https://api.anthropic.com/v1/messages",
      "apiKey": "${ANTHROPIC_API_KEY}",
      "capabilities": ["thinking", "vision", "coding"],
      "contextWindow": 200000,
      "cost": { "input": 3, "output": 15 }
    },
    "ollama-local": {
      "provider": "ollama",
      "endpoint": "http://localhost:11434/api/generate",
      "apiKey": "",
      "capabilities": ["coding", "general"],
      "contextWindow": 8192,
      "cost": { "input": 0, "output": 0 }
    },
    "qwen-coder": {
      "provider": "bailian",
      "endpoint": "https://coding.dashscope.com/v1",
      "apiKey": "${BAILIAN_API_KEY}",
      "capabilities": ["coding", "thinking"],
      "contextWindow": 1000000,
      "cost": { "input": 0.001, "output": 0.002 }
    },
    "minimax-m2.7": {
      "provider": "minimax",
      "endpoint": "https://api.minimaxi.com/anthropic/v1",
      "apiKey": "${MINIMAX_API_KEY}",
      "capabilities": ["thinking", "coding", "general"],
      "contextWindow": 204800,
      "cost": { "input": 0.3, "output": 1.2 }
    },
    "deepseek-coder": {
      "provider": "deepseek",
      "endpoint": "https://api.deepseek.com/v1",
      "apiKey": "${DEEPSEEK_API_KEY}",
      "capabilities": ["coding"],
      "contextWindow": 64000,
      "cost": { "input": 0.1, "output": 0.3 }
    }
  },
  "routing": {
    "lightTask": ["ollama-local"],
    "mediumTask": ["qwen-coder", "deepseek-coder"],
    "heavyTask": ["claude-3-5-sonnet", "minimax-m2.7"],
    "codingTask": ["claude-3-5-sonnet", "qwen-coder", "minimax-m2.7"]
  }
}

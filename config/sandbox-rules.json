{
  "allowedCommands": [
    "git", "npm", "npx", "node", "python", "python3", "pip", "pip3",
    "cargo", "make", "cmake", "gcc", "g++", "clang", "rustc", "go",
    "docker", "docker-compose", "kubectl", "helm",
    "curl", "wget", "ping", "traceroute", "nslookup",
    "ls", "dir", "pwd", "cd", "mkdir", "rm", "cp", "mv", "cat", "head", "tail",
    "grep", "find", "awk", "sed", "sort", "uniq", "wc", "diff",
    "tar", "zip", "unzip", "gzip", "gunzip",
    "code", "code-server", "nano", "vim", "vi", "emacs",
    "ps", "kill", "killall", "top", "htop",
    "df", "du", "free", "mount", "umount",
    "ssh", "scp", "rsync", "sftp",
    "terraform", "ansible", "vagrant",
    "jest", "vitest", "pytest", "pytest-cov",
    "eslint", "prettier", "black", "ruff",
    "webpack", "vite", "rollup", "esbuild",
    "tsc", "babel", "swc",
    "opencode", "claude", "codex", "qwen", "kimi"
  ],
  "blockedPatterns": [
    { "pattern": "rm\\s+-rf\\s+/", "severity": "critical", "description": "Recursive root delete" },
    { "pattern": "sudo\\s+", "severity": "high", "description": "Privilege escalation" },
    { "pattern": "curl.*--data.*password", "severity": "critical", "description": "Password in curl data" },
    { "pattern": "wget.*--password", "severity": "critical", "description": "Password in wget" },
    { "pattern": "chmod\\s+777", "severity": "medium", "description": "World-writable permissions" },
    { "pattern": "chmod\\s+4755", "severity": "high", "description": "SUID permission change" },
    { "pattern": "mkfs\\s+", "severity": "critical", "description": "Filesystem format" },
    { "pattern": "dd\\s+.*of=/dev/", "severity": "critical", "description": "Direct device write" },
    { "pattern": ">\\s*/etc/passwd", "severity": "critical", "description": "Write to system passwd" },
    { "pattern": "eval\\s+", "severity": "high", "description": "Dynamic code execution" },
    { "pattern": "bash\\s+-c\\s+.*\\$\\{", "severity": "high", "description": "Variable expansion injection" },
    { "pattern": ";\\s*rm\\s+-rf", "severity": "critical", "description": "Command chain delete" },
    { "pattern": "\\|\\s*sh\\s*$", "severity": "high", "description": "Pipe to shell" },
    { "pattern": "wget\\s+.*\\|\\s*bash", "severity": "critical", "description": "Download and execute" },
    { "pattern": "curl\\s+.*\\|\\s*bash", "severity": "critical", "description": "Curl and execute" }
  ],
  "maxFileSize": 10485760,
  "snapshotRetention": 50,
  "blockedExtensions": [".exe", ".dll", ".so", ".dylib"],
  "allowedNetworkHosts": [],
  "blockedNetworkHosts": ["*.onion", "*.i2p"],
  "timeoutSeconds": 300,
  "memoryLimitMB": 512
}
